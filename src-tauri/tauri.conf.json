{
	"$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
	"productName": "MarkLume",
	"version": "0.3.0",
	"identifier": "com.marklume.desktop",
	"build": {
		"beforeDevCommand": "npm run dev",
		"devUrl": "http://localhost:5173",
		"beforeBuildCommand": "npm run build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "MarkLume",
				"width": 1000,
				"height": 700,
				"minWidth": 600,
				"minHeight": 400,
				"backgroundColor": "#f5f5f5"
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": ["nsis"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.ico"
		],
		"fileAssociations": [
			{
				"description": "Markdown File",
				"ext": ["md", "markdown"],
				"mimeType": "text/markdown"
			},
			{
				"description": "Text File",
				"ext": ["txt"],
				"mimeType": "text/plain"
			}
		]
	}
}